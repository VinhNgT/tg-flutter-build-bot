# ==============================================================================
# Flutter Build Bot — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the values.
# Values set here can be overridden via the Web UI (saved config takes priority).
# Precedence: Web UI (saved) > env var > .env > hardcoded default

# ------------------------------------------------------------------------------
# Required
# ------------------------------------------------------------------------------

# Telegram bot token from @BotFather
# Example: 123456789:ABCdefGhIjKlMnOpQrStUvWxYz0123456789
TELEGRAM_BOT_TOKEN=

# Git clone URL for the Flutter project
# Example: https://gitlab.com/myorg/my-flutter-app.git
REPO_URL=

# Comma-separated Telegram chat IDs allowed to use the bot
# Use @userinfobot or @RawDataBot to find your chat ID
# Example: -1001234567890,-1009876543210
ALLOWED_CHAT_IDS=

# Google OAuth2 credentials for Google Drive uploads
# Get these from: https://console.cloud.google.com/apis/credentials
# Create an OAuth client ID (Web application) and set the redirect URI to:
#   http://localhost:8080/oauth/callback
# Example: 123456789012-abcdefghijklmnop.apps.googleusercontent.com
GOOGLE_CLIENT_ID=
# Example: GOCSPX-AbCdEfGhIjKlMnOpQrStUvWxYz
GOOGLE_CLIENT_SECRET=

# ------------------------------------------------------------------------------
# Optional (have hardcoded defaults)
# ------------------------------------------------------------------------------

# GitLab Personal Access Token for cloning private repositories
# Create one at: https://gitlab.com/-/user_settings/personal_access_tokens
# Required scope: read_repository
# Example: glpat-xxxxxxxxxxxxxxxxxxxx
# GITLAB_PAT=

# Shell command to build the Flutter project (run inside the cloned repo)
# Default: flutter build apk --release
# BUILD_COMMAND=flutter build apk --release

# Path to the build artifact, relative to the repo root
# Default: build/app/outputs/flutter-apk/app-release.apk
# BUILD_OUTPUT_PATH=build/app/outputs/flutter-apk/app-release.apk

# Minimum seconds between builds (prevents spamming)
# Default: 300
# COOLDOWN_SECONDS=300

# Maximum number of builds to keep (oldest are pruned from local + Drive)
# Default: 3
# MAX_BUILDS=3

# Google Drive folder name for uploaded APKs
# Default: {project-name}-tg-flutter-build-bot (derived from repo URL)
# DRIVE_FOLDER_NAME=my-app-tg-flutter-build-bot

# Port for the admin Web UI
# Default: 8080
# WEB_PORT=8080
